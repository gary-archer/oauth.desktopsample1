{
  "name": "basicdesktopapp",
  "version": "1.0.0",
  "description": "An OpenID Connect secured Desktop App using the AppAuth-JS security",
  "keywords": [],
  "author": "Gary Archer",
  "license": "MIT",
  "main": "main.bundle.js",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "lint": "npx eslint . --ignore-pattern dist",
    "build": "npm run webpackMain && npm run webpackRenderer",
    "start": "./start.sh",
    "webpackMain": "NODE_OPTIONS='--import tsx' webpack --config webpack/main.config.ts",
    "webpackRenderer": "NODE_OPTIONS='--import tsx' webpack --config webpack/renderer.config.ts"
  },
  "dependencies": {
    "@openid/appauth": "^1.3.1",
    "axios": "^1.7.7",
    "base64url": "^3.0.1",
    "fs-extra": "^11.2.0",
    "get-port": "^7.1.0",
    "https-proxy-agent": "^7.0.5",
    "mustache": "^4.2.0",
    "open": "^10.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "@types/fs-extra": "^11.0.4",
    "@types/mustache": "^4.2.5",
    "@types/node": "^20.16.13",
    "electron": "^33.0.1",
    "eslint": "^9.13.0",
    "ts-loader": "^9.5.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.10.0",
    "webpack": "^5.94.0",
    "webpack-cli": "^5.1.4"
  }
}
